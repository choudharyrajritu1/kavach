# ---- LLM mode ----
# mock = fully offline, deterministic (default; great for demos/CI)
# live = call a real OpenAI-compatible provider below
KAVACH_LLM_MODE=mock

# ---- Provider (used only when KAVACH_LLM_MODE=live) ----
KAVACH_PROVIDER=Together
KAVACH_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
KAVACH_TEMPERATURE=0.2
KAVACH_MAX_TOKENS=2048
# Set the key matching the provider:
# TOGETHER_API_KEY=your_key_here
# CEREBRAS_API_KEY=your_key_here
# KAVACH_PROVIDER=Fireworks
# KAVACH_MODEL=accounts/fireworks/models/deepseek-v4-pro
# FIREWORKS_API_KEY=your_key_here
# For a local OpenAI-compatible server (vLLM/Ollama/LM Studio):
# KAVACH_PROVIDER=Local
# KAVACH_LOCAL_BASE_URL=http://localhost:8001/v1
# KAVACH_LOCAL_API_KEY=not-needed

# ---- Data sources ----
# offline=true uses bundled sample CVEs; false fetches from NVD.
KAVACH_OFFLINE=true
KAVACH_NVD_API_BASE=https://services.nvd.nist.gov/rest/json/cves/2.0
# KAVACH_NVD_API_KEY=your_nvd_key_here
# Google search via SerpAPI (scripts/google_search.py, optional collector enrichment)
# SERPAPI_API_KEY=your_serpapi_key_here

# ---- Sandbox ----
# Requires Docker. When false/unavailable, the Verifier uses a safe dry-run.
KAVACH_SANDBOX_ENABLED=false
KAVACH_SANDBOX_TIMEOUT=120

# ---- Mode & exploitation ----
# defensive (default) = benign verification only.
# offensive = enable the Exploiter agent to generate a REAL PoC and run it
#             against an AUTHORIZED target (local lab twin or allowlisted host).
KAVACH_MODE=defensive
# Explicit authorized target URL (offensive mode). Loopback/RFC1918 are always
# allowed as "lab"; any other host MUST be listed here or in the allowlist.
# KAVACH_AUTHORIZED_TARGET=http://127.0.0.1:8080/
# Comma-separated extra hostnames you are authorized to test:
# KAVACH_TARGET_ALLOWLIST=app.localtest.me,my-lab.internal
KAVACH_EXPLOIT_MAX_ITERATIONS=3
# For Log4Shell callback detection against a remote authorized target, set the
# address the target can reach back on:
# KAVACH_CALLBACK_HOST=10.0.0.5

# ---- Orchestration / storage ----
KAVACH_MAX_AGENT_RETRIES=2
# KAVACH_DB_PATH=./data/kavach.db

# ---- Safety ----
# When true, the Judge marks runs as needs_review instead of done.
KAVACH_HUMAN_REVIEW=false
